{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local"
    ],
    "globalEnv": [
        "TS_NODE",
        "NODE_ENV",
        "PORT"
    ],
    "pipeline": {
        "@w8nc/api#build": {
            "dependsOn": [
                "@w8nc/database#build",
                "@w8nc/logger#build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "@w8nc/database#build": {
            "outputs": [
                "dist/**"
            ]
        },
        "@w8nc/logger#build": {
            "outputs": [
                "dist/**"
            ]
        },
        "@w8nc/ui#build": {
            "outputs": [
                "dist/**"
            ]
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "public/dist/**"
            ]
        },
        "db:migrate:deploy": {},
        "db:push": {},
        "db:seed": {},
        "dev": {
            "dependsOn": [
                "@w8nc/database#build",
                "@w8nc/logger#build",
                "@w8nc/ui#build"
            ],
            "cache": false
        },
        "generate": {
            "dependsOn": [
                "^generate"
            ]
        },
        "lint": {},
        "clean": {
            "cache": false
        }
    }
}
